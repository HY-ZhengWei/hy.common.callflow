<?xml version="1.0" encoding="UTF-8"?>

<config>

    <import name="xcallFlow" class="org.hy.common.callflow.common.CallFlowImports" />
    
    
    
    <!-- CFlow编排引擎配置 -->
    <xconfig>
    
        <xnode id="XNode_CF002_1_1_2">
            <comment>第三个环节，为假时的走向</comment>
            <callXID>:XProgram</callXID>
            <callMethod>method_False</callMethod>
        </xnode>
        
        
        <xnode id="XNode_CF002_1_1_1">
            <comment>第三个环节，为真时的走向</comment>
            <callXID>:XProgram</callXID>
            <callMethod>method_True</callMethod>
        </xnode>
        
        
        <xcondition id="XCondition_CF002_1_1">
            <comment>第二个环节，条件逻辑，按第一个环节的执行结果（真、假）控制编排的走向</comment>
            <logical>AND</logical>                          <!-- 判定逻辑（可以不用显式定义。默认为AND） -->
            <conditionItem>
                <valueClass>java.lang.String</valueClass>   <!-- 定义变量类型 -->
                <valueXIDA>T</valueXIDA>                    <!-- 默认值 -->
                <comparer>==</comparer>                     <!-- 判定比较器（可以不用显式定义。默认为==） -->
                <valueXIDB>:IfElse.name</valueXIDB>         <!-- 变量 -->
            </conditionItem>
            <route>
                <if>                                        <!-- 真时的路由 -->
                    <next ref="XNode_CF002_1_1_1" />
                    <comment>真时</comment>
                </if>
                <else>                                      <!-- 假时的路由 -->
                    <next ref="XNode_CF002_1_1_2" />
                    <comment>假时</comment>
                </else>
            </route>
            <mock>
                <valid>true</valid>                         <!-- Mock模拟是否有效 -->
                <succeed>                                   <!-- Mock模拟成功时 -->
                    <enable>:MockSucceed</enable>           <!-- Mock模拟成功时的生效变量 -->
                    <data>-1</data>                         <!-- Mock模拟结果为：假 -->
                </succeed>
            </mock>
        </xcondition>
        
        
        <xapi id="XCFlow_LLMGate_Weather">
            <comment>天气查询</comment>
            <url>https://restapi.amap.com/v3/weather/weatherInfo?</url>
            <param><![CDATA[key=a75b4788b5ceffd2761ba2fdd1b9b151&city=610400]]></param>
            <body>
            {
                "name": :IfElse.name
            }
            </body>
            <succeedFlag>"OK"</succeedFlag>
            <returnID>RetWeather</returnID>
            <route>
                <succeed>                                   <!-- 成功时，关联后置节点 -->
                    <next ref="XCondition_CF002_1_1" />
                    <comment>成功时</comment>
                </succeed>
            </route>
        </xapi>
        
        
        <xnode id="XNode_CF002_1">
            <comment>第一个环节，有一个参数，有返回结果</comment>
            <callXID>:XProgram</callXID>
            <callMethod>method_RetaMap</callMethod>
            <callParam>
                <valueClass>java.lang.Integer</valueClass>  <!-- 定义入参类型 -->
                <value>:NumParam</value>                    <!-- 定义入参变量名称 -->
                <valueDefault>-1</valueDefault>             <!-- 定义入参默认值 -->
            </callParam>
            <returnID>IfElse</returnID>                     <!-- 定义返回结果的变量名称 -->
            <route>
                <succeed>                                   <!-- 成功时，关联后置节点 -->
                    <next ref="XCFlow_LLMGate_Weather" />
                    <comment>成功时</comment>
                </succeed>
            </route>
            <mock>
                <valid>true</valid>                         <!-- Mock模拟是否有效 -->
                <dataClass>java.util.HashMap</dataClass>
                <succeed>                                   <!-- Mock模拟成功时 -->
                    <comment>模拟成功结果</comment>
                    <enable>:MockSucceed</enable>           <!-- Mock模拟成功时的生效变量 -->
                    <data>
                    {
                        "name": "T",
                        "value": "123"
                    }
                    </data>                          <!-- Mock模拟成功时的模拟数据 -->
                </succeed>
            </mock>
        </xnode>
        
    </xconfig>
    
</config>