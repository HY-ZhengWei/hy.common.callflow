<?xml version="1.0" encoding="UTF-8"?>

<config>

    <import name="xcallFlow" class="org.hy.common.callflow.common.CallFlowImports" />
    
    
    
    <!-- CFlow编排引擎配置：集群批量更新操作系统（集群并发） -->
    <xconfig>
    
        <xnode id="XNodee_CF037_UpgradeCluster_更新结果">
            <comment>显示结果</comment>
            <callXID>:XProgram</callXID>
            <callMethod>method_Show</callMethod>
            <callParam>
                <value>:UpgradeResult</value>
            </callParam>
        </xnode>
        
        
        <xshell id="XShell_CF037_UpgradeCluster_更新系统">
            <comment>更新操作系统</comment>
            <host>:ClusterElement.ip</host>                        <!-- 主机IP地址 -->
            <user>:ClusterElement.user</user>                      <!-- 用户名称 -->
            <password>:ClusterElement.pwd</password>               <!-- 用户密码 -->
            <showLog>true</showLog>                                <!-- 显示实时日志 -->
            <shell type="textarea">                        
                echo ":ClusterElement.pwd" | sudo -S apt upgrade -y
            </shell>                                               <!-- Shell代码 -->
            <returnID>UpgradeResult</returnID>
            <route>
                <succeed>                                  
                    <next ref="XNodee_CF037_UpgradeCluster_更新结果" />
                </succeed>
            </route>
        </xshell>
        
        
        <xnode id="XNodee_CF037_UpgradeCluster_资源结果">
            <comment>显示结果</comment>
            <callXID>:XProgram</callXID>
            <callMethod>method_Show</callMethod>
            <callParam>
                <value>:UpdateResult</value>
            </callParam>
            <route>
                <succeed>                                  
                    <next ref="XShell_CF037_UpgradeCluster_更新系统" />
                </succeed>
            </route>
        </xnode>
        
    
        <xshell id="XShell_CF037_UpgradeCluster_更新资源">
            <comment>更新软件资源</comment>
            <initXID>:XShell_CF037_UpgradeCluster_更新系统</initXID> <!-- 用参考对象配置连接信息 -->
            <showLog>true</showLog>                                <!-- 显示实时日志 -->
            <shell type="textarea">                        
                echo ":ClusterElement.pwd" | sudo -S apt update -y
            </shell>                                               <!-- Shell代码 -->
            <returnID>UpdateResult</returnID>
            <route>
                <succeed>                                  
                    <next ref="XNodee_CF037_UpgradeCluster_资源结果" />
                </succeed>
                <error>                                  
                    <next ref="XNodee_CF037_UpgradeCluster_更新结果" />
                </error>
            </route>
        </xshell>
        
        
        <xnode id="XNodee_CF037_UpgradeCluster_准备开始">
            <comment>显示准备开始</comment>
            <callXID>:XProgram</callXID>
            <callMethod>method_Begin</callMethod>
            <callParam>
                <value>:ClusterIndex</value>
            </callParam>
            <callParam>
                <value>:ClusterElement.ip</value>
            </callParam>
            <callParam>
                <value>:ForElement.msType</value>
            </callParam>
            <route>
                <succeed>                                  
                    <next ref="XShell_CF037_UpgradeCluster_更新资源" />
                </succeed>
            </route>
        </xnode>
        
        
        <xreturn id="XRetur_CF037_UpgradeCluster_全部完成">
            <comment>全部完成</comment>
            <retValue>
            {
                "retInt": 200,
                "retText": "全部完成"
            }
            </retValue>
        </xreturn>
        
        
        <xmt id="XMT_CF037_UpgradeCluster_服务列表">
            <comment>按服务列表集群并发</comment>
            <clusterXID>:ServerList</clusterXID>                   <!-- 集合对象的变量名称 -->
            <clusterElementID>ClusterElement</clusterElementID>    <!-- 每次并发项的变量名称（可选的） -->
            <clusterIndexNo>ClusterIndex</clusterIndexNo>          <!-- 序号变量名称（可选的），下标从1开始 -->
            <item>
                <callFlowXID>:XNodee_CF037_UpgradeCluster_准备开始</callFlowXID>
            </item>
            <route>
                <succeed>                                          <!-- 成功时，关联后置节点 -->
                    <next ref="XRetur_CF037_UpgradeCluster_全部完成" />
                </succeed>
            </route>
        </xmt>
        
    </xconfig>
    
</config>