<?xml version="1.0" encoding="UTF-8"?>

<config>

    <import name="xcallFlow" class="org.hy.common.callflow.common.CallFlowImports" />
    
    
    
    <!-- CFlow编排引擎配置 -->
    <xconfig>
    
        <xwspush id="XWSPush">
            <comment>点推元素</comment>
            <name>pushName</name>
            <newMessage>
                {
                    "Message": :Message,
                    "K1": ":K1",
                    "K2": ":K2"
                }
            </newMessage>
        </xwspush>
        
    </xconfig>
    
</config>