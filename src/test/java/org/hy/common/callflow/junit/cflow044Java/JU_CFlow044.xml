<?xml version="1.0" encoding="UTF-8"?>

<config>

    <import name="xcallFlow" class="org.hy.common.callflow.common.CallFlowImports" />
    
    
    
    <!-- CFlow编排引擎配置：爪哇元素 -->
    <xconfig>
    
        <xreturn id="XNode_CF044_显示结果">
            <comment>显示结果</comment>
            <retValue>
            {
                "retInt": 200,
                "retText": "执行结果为：:DynamicData.name"
            }
            </retValue>
        </xreturn>    
        
    
        <xnode id="XNode_CF044_属性赋值">
            <comment>对创建出来的实例属性赋值</comment>
            <callXID>:DynamicData</callXID>
            <callMethod>setName</callMethod>
            <callParam>
                <valueClass>java.lang.String</valueClass>   <!-- 定义入参类型 -->
                <value>:Name</value>                        <!-- 定义入参变量名称 -->
                <valueDefault>爪哇元素</valueDefault>          <!-- 定义入参默认值 -->
            </callParam>
            <route>
                <succeed>
                    <next ref="XNode_CF044_显示结果" />
                </succeed>
            </route>
        </xnode>
    
    
        <xnode id="XNode_CF044_创建实例">
            <comment>在运行时，编译源码后创建它的实例</comment>
            <callXID>:DynamicClass</callXID>
            <callMethod>newInstance</callMethod>            <!-- 爪哇元素返回结果的预设方法 -->
            <returnID>DynamicData</returnID>
            <route>
                <succeed>
                    <next ref="XNode_CF044_属性赋值" />
                </succeed>
            </route>
        </xnode>
        
        
        <xjava id="XJava_CF044_定义对象">
            <comment>在运行时，编译源码，动态定义对象</comment>
            <java type="textarea">                          <!-- Java代码 -->
            <![CDATA[
            package org.hy.common.callflow.junit.cflow044Java;
                
            import org.hy.common.Date;
            import lombok.Data;
            
            @Data
            public class DynamicInfo
            {
                /** 名称 */
                private String name;
                
                @Override
                public String toString()
                {
                    return Date.getNowTime().getFull();
                }
            }
            ]]>
            </java>
            <returnID>DynamicClass</returnID>               <!-- 定义返回结果的变量名称。名称相同时会覆盖 -->
            <route>
                <succeed>                                   <!-- For循环结束点（再次循环点） -->
                    <next>:XFor_CF044_循环定义</next>
                    <comment>循环的下一步</comment>
                </succeed>
                <succeed>
                    <next ref="XNode_CF044_创建实例" />
                    <comment>成功时</comment>
                </succeed>
            </route>
        </xjava>
        
        
        <xfor id="XFor_CF044_循环定义">
            <comment>循环：1到3</comment>
            <start>1</start>                                <!-- 循环开始值 -->
            <end>3</end>                                    <!-- 循环结束值 -->
            <step>1</step>                                  <!-- 步长，可选项，默认为1 -->
            <indexID>ForIndex</indexID>                     <!-- 序号变量名称 -->
            <route>
                <succeed>                                   <!-- 成功时，关联后置节点 -->
                    <next ref="XJava_CF044_定义对象" />
                    <comment>For循环</comment>
                </succeed>
            </route>
        </xfor>
        
    </xconfig>
    
</config>