<?xml version="1.0" encoding="UTF-8"?>

<config>

    <import name="xcallFlow" class="org.hy.common.callflow.common.CallFlowImports" />
    
    
    
    <!-- CFlow编排引擎配置：无限循环 -->
    <!-- 须扩大内存，配置举例： -Xmx1G -XX:MetaspaceSize=512M -Xss1G -->
    <xconfig>
    
        <xnode id="XNode_CF040_Finish">
            <comment>完成</comment>
            <callXID>:XProgram</callXID>
            <callMethod>finish</callMethod>
        </xnode>
        
    
        <xnode id="XNode_CF040_Loop">
            <comment>无限循环</comment>
            <callXID>:XProgram</callXID>
            <callMethod>loop</callMethod>
            <callParam>
                <value>:CallFlowContext</value>             <!-- 系统预设的上下文内容变量名称 -->
            </callParam>
            <route>
                <succeed>
                    <next>:XWait_CF040_Wait</next>
                </succeed>
            </route>
        </xnode>
        
    
        <xwait id="XWait_CF040_Wait">
            <comment>等待1秒</comment>
            <waitTime>1</waitTime>                          <!-- 等待时长（单位：毫秒） -->
            <counter>Counter</counter>
            <counterMax>12000</counterMax>                  <!-- 20分钟 -->
            <route>
                <if>                                        <!-- 自引用 -->
                    <next ref="XNode_CF040_Loop" />
                    <comment>While循环的下一步</comment>
                </if>
                <else>
                    <next ref="XNode_CF040_Finish" />
                </else>
            </route>
        </xwait>
        
    
        <xnode id="XNode_CF040_Start">
            <comment>准备开始无限循环</comment>
            <callXID>:XProgram</callXID>
            <callMethod>start</callMethod>
            <route>
                <succeed>
                    <next ref="XWait_CF040_Wait" />
                </succeed>
            </route>
        </xnode>
        
    </xconfig>
    
</config>